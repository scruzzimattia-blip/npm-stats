# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=npm_monitor
DB_USER=npm_user
DB_PASSWORD=YOUR_LOCAL_POSTGRES_PASSWORD
DB_POOL_MIN=1
DB_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Paths
LOG_DIR=/var/log/npm
GEOIP_DB_PATH=/usr/share/GeoIP/GeoLite2-City.mmdb
NPM_DB_SQLITE_PATH=/home/mattia/media-stack/config/npm/data/database.sqlite

# Security
ENABLE_AUTH=true
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE_THIS_PASSWORD
ALLOWED_NETWORKS=0.0.0.0/0
ENABLE_BLOCKING=true
BLOCK_DURATION=3600
USE_FIREWALL=false

# NPM Database Auto-Discovery (Local)
NPM_DB_TYPE=sqlite
NPM_DB_HOST=localhost
NPM_DB_PORT=3306
NPM_DB_USER=npm
NPM_DB_PASSWORD=
NPM_DB_NAME=npm

# Alerting
NOTIFY_ON_BLOCK=true
# WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# NTFY_TOPIC=

# AI (OpenRouter)
OPENROUTER_API_KEY=
AI_MODEL=google/gemini-2.0-flash-lite:free
ENABLE_AI_AUTO_ANALYSIS=false
