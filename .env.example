# NPM Monitor Configuration
# Copy this file to .env and adjust the values

# Image Version (Git tag or 'latest')
VERSION=latest

# Database Configuration
DB_HOST=npm-monitor-db
DB_PORT=5432
DB_NAME=npm_monitor
DB_USER=npm_user
DB_PASSWORD=change_this_secure_password
DB_POOL_MIN=1
DB_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Settings
LOG_DIR=/logs
LINES_PER_FILE=10000
MAX_DISPLAY_ROWS=50000
RETENTION_DAYS=30

# Performance Settings
# Query timeout in seconds (default: 30)
QUERY_TIMEOUT=30
# Cache time-to-live in seconds (default: 300 = 5 minutes)
CACHE_TTL=300
# Number of parallel workers for log parsing (default: auto-detect CPU count)
MAX_WORKERS=8
# File read chunk size in bytes (default: 65536)
CHUNK_SIZE=65536

# GeoIP Settings
# Get free license key at: https://www.maxmind.com/en/geolite2/signup
ENABLE_GEOIP=true
GEOIP_DB_PATH=/geoip/GeoLite2-City.mmdb
MAXMIND_ACCOUNT_ID=your_account_id
MAXMIND_LICENSE_KEY=your_license_key

# Custom IPs to ignore (comma-separated)
IGNORED_IPS=

# Security Settings
ENABLE_AUTH=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_secure_password_too
ALLOWED_NETWORKS=127.0.0.1/32,192.168.1.0/24

# Auto-Blocking Settings (Fail2Ban-like)
ENABLE_BLOCKING=true
BLOCK_DURATION=3600
MAX_404_ERRORS=20
MAX_403_ERRORS=10
MAX_5XX_ERRORS=50
MAX_FAILED_REQUESTS=100
MAX_REQUESTS_PER_MINUTE=60
MAX_SUSPICIOUS_PATHS=5
SUSPICIOUS_PATHS=/wp-admin,/wp-login.php,/phpmyadmin,/admin,/login,.env,.git,/config.php,/backup,/sql
SENSITIVE_PATHS=/login,/admin,/api/auth,/config,/setup,/install,/manage,/db-admin

# Honeypot Settings
HONEY_PATHS=/.env,/.git/config,/wp-config.php,/config.php,/backup.sql,/dump.sql
HONEY_POT_DURATION=31536000

# WAF Settings
WAF_DRY_RUN=false
ENABLE_ADAPTIVE_BLOCKING=true

# Firewall Integration (use host-based script instead of container)
USE_FIREWALL=false

# Cloudflare Settings
ENABLE_CLOUDFLARE=false
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ZONE_ID=your_zone_id

# Anomaly Detection
ENABLE_ANOMALY_DETECTION=true
SPIKE_THRESHOLD_FACTOR=3.0
SPIKE_MIN_REQUESTS=50

# CrowdSec Integration
ENABLE_CROWDSEC=false
CROWDSEC_API_URL=http://localhost:8080
CROWDSEC_API_KEY=your_lapi_key

# Notification Settings
WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_ON_BLOCK=true

# ntfy.sh Notifications
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_PRIORITY=default

# Email / SMTP Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=npm-monitor@example.com
SMTP_TO=

# AI Analysis (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_key
AI_MODEL=google/gemini-2.0-flash-lite:free
ENABLE_AI_AUTO_ANALYSIS=false

# Geo-Blocking (comma-separated country codes)
BLOCKED_COUNTRIES=
ALLOW_ONLY_COUNTRIES=
