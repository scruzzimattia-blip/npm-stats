# NPM Monitor Configuration
# Copy this file to .env and adjust the values

# Database Configuration
DB_HOST=npm-monitor-db
DB_PORT=5432
DB_NAME=npm_monitor
DB_USER=npm_user
DB_PASSWORD=change_this_secure_password
DB_POOL_MIN=1
DB_POOL_MAX=10

# Application Settings
LOG_DIR=/logs
LINES_PER_FILE=10000
MAX_DISPLAY_ROWS=50000
RETENTION_DAYS=30

# GeoIP Settings
# Get free license key at: https://www.maxmind.com/en/geolite2/signup
ENABLE_GEOIP=true
GEOIP_DB_PATH=/geoip/GeoLite2-City.mmdb
MAXMIND_ACCOUNT_ID=your_account_id
MAXMIND_LICENSE_KEY=your_license_key

# Custom IPs to ignore (comma-separated)
IGNORED_IPS=

# Security Settings
ENABLE_AUTH=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change_this_secure_password_too
ALLOWED_NETWORKS=127.0.0.1/32,192.168.1.0/24

# Auto-Blocking Settings (Fail2Ban-like)
ENABLE_BLOCKING=true
BLOCK_DURATION=3600
MAX_404_ERRORS=20
MAX_403_ERRORS=10
MAX_5XX_ERRORS=50
MAX_FAILED_REQUESTS=100
SUSPICIOUS_PATHS=/wp-admin,/wp-login.php,/phpmyadmin,/admin,/login,.env,.git,/config.php,/backup,/sql

# Firewall Integration (use host-based script instead of container)
USE_FIREWALL=false
